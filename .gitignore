# ============================================================================
# .gitignore — Sudoku AI Solver Pro
# Professional ignore rules for Python + Web + Dev environment
# ============================================================================


# ---------------------------------------------------------------------------
# Python (bytecode, cache)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class


# ---------------------------------------------------------------------------
# Virtual Environment
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/


# ---------------------------------------------------------------------------
# Distribution / Packaging
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/


# ---------------------------------------------------------------------------
# Logs & Runtime Files
# ---------------------------------------------------------------------------
*.log
*.out
*.err


# ---------------------------------------------------------------------------
# Environment Variables (IMPORTANT)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example


# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------

# VSCode
.vscode/

# PyCharm / IntelliJ
.idea/

# Sublime
*.sublime-project
*.sublime-workspace


# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db


# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/


# ---------------------------------------------------------------------------
# Node / Frontend (for web UI)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ---------------------------------------------------------------------------
# Temporary / Misc
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.swp


# ---------------------------------------------------------------------------
# Generated Sudoku / Benchmark Outputs (optional)
# ---------------------------------------------------------------------------
outputs/
benchmarks/
